{
  "name": "@brusdeylins/pptc",
  "version": "0.11.0",
  "description": "Deterministic PowerPoint (PPTX) CLI for LLM agents: template-aware creation and editing with atomic, schema-validated operations",
  "keywords": [
    "pptx",
    "powerpoint",
    "cli",
    "llm",
    "agent",
    "ooxml",
    "presentation",
    "template"
  ],
  "license": "MIT",
  "author": "Matthias Brusdeylins <brusdeylins@gmx.de>",
  "homepage": "https://github.com/brusdeylins/ppt-skill",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brusdeylins/ppt-skill.git"
  },
  "bugs": {
    "url": "https://github.com/brusdeylins/ppt-skill/issues"
  },
  "type": "module",
  "bin": {
    "pptc": "dst/pptc.mjs"
  },
  "files": [
    "dst",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "plugin:sync": "npm run build && cp dst/pptc.mjs plugin/skills/ppt/scripts/pptc.mjs && node -e \"const fs=require('fs');const v=require('./package.json').version+'\\n';fs.writeFileSync('plugin/skills/ppt/scripts/VERSION',v);fs.writeFileSync('plugin/skills/ppt-prepare/VERSION',v)\"",
    "skill:zip": "npm run plugin:sync && node scripts/skill-zip.mjs",
    "skill:zip:internal": "npm run plugin:sync && node scripts/skill-zip.mjs --internal",
    "test": "vitest run",
    "lint": "eslint src test && tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "pretest": "npm run build"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.0",
    "jszip": "^3.10.1",
    "pptx-automizer": "^0.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "pptxgenjs": "^4.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
